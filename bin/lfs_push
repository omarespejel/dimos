#!/bin/bash
# Compresses directories in data/* into data/.lfs/dirname.tar.gz
# Pushes to LFS

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# --- LFS auth setup ---
# Our LFS server (lfs.dimensionalos.com) validates push access via GitHub PAT.
# Only collaborators with write access on dimensionalOS/dimos can push.
# We use the gh CLI to provide credentials automatically.
if ! command -v gh &>/dev/null; then
    echo -e "${RED}✗${NC} 'gh' CLI not found. Install it: https://cli.github.com"
    echo -e "  Then run: gh auth login"
    exit 1
fi
if ! gh auth status &>/dev/null 2>&1; then
    echo -e "${RED}✗${NC} 'gh' CLI not authenticated. Run: gh auth login"
    exit 1
fi

# Credential helper scoped to our LFS server: when git-lfs gets a 401 from
# lfs.dimensionalos.com it asks git for credentials, and this helper answers
# with a fresh token from `gh`. Note `gh auth git-credential` can NOT be used
# here — it only answers for github.com hosts. Scoped to this one URL, so
# pushes to github.com (or anywhere else) are unaffected.
git config --global --replace-all 'credential.https://lfs.dimensionalos.com.helper' \
    '!f() { if [ "$1" = "get" ]; then echo "username=token"; echo "password=$(gh auth token)"; fi; }; f'
echo -e "${GREEN}✓${NC} Configured LFS credential helper for lfs.dimensionalos.com"

#echo -e "${GREEN}Running test data compression check...${NC}"

ROOT=$(git rev-parse --show-toplevel)
cd $ROOT

TAR_PROGRESS=()
if tar --version 2>/dev/null | grep -q "GNU tar"; then
    TAR_PROGRESS=(--checkpoint=1000 --checkpoint-action=dot)
fi

# Check if data/ exists
if [ ! -d "data/" ]; then
    echo -e "${YELLOW}No data directory found, skipping compression.${NC}"
    exit 0
fi

# Track if any compression was performed
compressed_entries=()

# Iterate through every entry in data/ (files and directories — tar handles both).
for entry_path in data/*; do
    # Skip if glob didn't match anything
    [ ! "$entry_path" ] && continue

    # Extract directory name
    entry_name=$(basename "$entry_path")

    # Skip .lfs directory if it exists
    [ "$entry_name" = ".lfs" ] && continue

    # Skip SQLite ephemeral sidecar files (WAL / shared memory / rollback journal).
    # These are runtime-only and would otherwise produce useless tarballs in LFS.
    case "$entry_name" in
        *-wal|*-shm|*-journal) continue ;;
    esac

    # Define compressed file path
    compressed_file="data/.lfs/${entry_name}.tar.gz"

    # Check if compressed file already exists
    if [ -f "$compressed_file" ]; then
        continue
    fi

    echo -e "  ${YELLOW}Compressing${NC} $entry_path -> $compressed_file"

    # Show directory size before compression
    entry_size=$(du -sh "$entry_path" | cut -f1)
    echo -e "    Data size: ${YELLOW}$entry_size${NC}"

    # Create compressed archive with progress bar
    # Use tar with gzip compression, excluding hidden files and common temp files
    tar -czf "$compressed_file" \
        --exclude='*.tmp' \
        --exclude='*.temp' \
        --exclude='.DS_Store' \
        --exclude='Thumbs.db' \
        "${TAR_PROGRESS[@]}" \
        -C "data/" \
        "$entry_name"

    if [ $? -eq 0 ]; then
        # Show compressed file size
        compressed_size=$(du -sh "$compressed_file" | cut -f1)
        echo -e "  ${GREEN}✓${NC} Successfully compressed $entry_name (${GREEN}$entry_size${NC} → ${GREEN}$compressed_size${NC})"
        compressed_entries+=("$entry_name")

        # Add the compressed file to git LFS tracking
        git add -f "$compressed_file"

        echo -e "  ${GREEN}✓${NC} git-add $compressed_file"

    else
        echo -e "  ${RED}✗${NC} Failed to compress $entry_name"
        exit 1
    fi
done

if [ ${#compressed_entries[@]} -gt 0 ]; then
    # Create commit message with compressed directory names
    if [ ${#compressed_entries[@]} -eq 1 ]; then
        commit_msg="Auto-compress test data: ${compressed_entries[0]}"
    else
        # Join array elements with commas
        entries_list=$(IFS=', '; echo "${compressed_entries[*]}")
        commit_msg="Auto-compress test data: ${entries_list}"
    fi

    #git commit -m "$commit_msg"
    echo -e "${GREEN}✓${NC} Compressed file references added. Uploading..."
    # Use a temp askpass script so the token never leaks into process args.
    _lfs_askpass=$(mktemp)
    chmod 700 "$_lfs_askpass"
    cat > "$_lfs_askpass" << 'ASKPASS'
#!/bin/sh
case "$1" in
  *sername*) echo "token" ;;
  *assword*) gh auth token ;;
esac
ASKPASS
    GIT_ASKPASS="$_lfs_askpass" GIT_TERMINAL_PROMPT=0 \
        git -c credential.helper= lfs push origin $(git branch --show-current)
    rm -f "$_lfs_askpass"
    echo -e "${GREEN}✓${NC} Uploaded to LFS"
else
    echo -e "${GREEN}✓${NC} No test data to compress"
fi
